#include? "Pods/Target Support Files/Pods-Runner/Pods-Runner.release.xcconfig"
#include "Generated.xcconfig"

// Override generated build dir settings to avoid mixing simulator/device artifacts.
CONFIGURATION_BUILD_DIR = $(BUILD_DIR)/$(CONFIGURATION)$(EFFECTIVE_PLATFORM_NAME)

// Separate Flutter build outputs per platform to avoid native-assets collisions.
FLUTTER_BUILD_DIR = build_ios$(EFFECTIVE_PLATFORM_NAME)
